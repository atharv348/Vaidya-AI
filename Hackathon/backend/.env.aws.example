# Backend environment values for AWS deployments

# Required secrets
GROQ_API_KEY=replace-with-groq-api-key
SECRET_KEY=replace-with-a-long-random-secret

# Auth configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Runtime configuration
PORT=8000
PYTHONUNBUFFERED=1

# Prefer PostgreSQL on AWS RDS in production
# Example: postgresql+psycopg2://app_user:app_pass@your-rds-endpoint:5432/pragyantra
DATABASE_URL=sqlite:///./pragyantra.db

# Replace with your real frontend domains
CORS_ORIGINS=https://your-frontend-domain.com,https://main.your-amplify-domain.amplifyapp.com
