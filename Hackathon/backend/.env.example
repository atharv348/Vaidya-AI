# Pragyantra Backend Environment Configuration
# Copy this file to .env and add your values

# Groq API Key for AI Features
# Get your free API key from https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# JWT Secret Key (Change this in production!)
SECRET_KEY=pragyantra-secret-key-change-in-production-09876543210987654321

# Database URL (SQLite by default, can be changed to PostgreSQL/MySQL)
DATABASE_URL=sqlite:///./pragyantra.db

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://pragyantra.vercel.app

# JWT Algorithm
JWT_ALGORITHM=HS256

# JWT Token Expiry (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Python Unbuffered Output (for logs in production)
PYTHONUNBUFFERED=1
